{
  "description": "Load beads session context at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/prime.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
